{
  "version": 2,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/_serverFn/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!assets|favicon.ico|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
